{
  "name": "create-mc-plugin",
  "description": "Modern Minecraft Plugin Template Generator",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "create-mc-plugin": "dist/index.js"
  },
  "files": [
    "dist",
    "templates/**",
    "templates/**/.*",
    "templates/**/.idea",
    "templates/**/.idea/**",
    "templates/**/.gitignore",
    "templates/**/*.iml"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "enquirer": "^2.4.1",
    "fs-extra": "^11.3.4"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^25.4.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}